class Solution {
    public int lengthOfLastWord(String s) {
        int length = 0;
        
        for (int i = s.length() - 1; i >= 0; i--) {
            if (s.charAt(i) != ' ') {
                length++;
            } else if (length > 0) {
                // If we've already started counting and hit a space, 
                // we have finished the last word!
                break;
            }
        }
        
        return length;
    }
}
