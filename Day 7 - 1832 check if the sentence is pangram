class Solution {
    public boolean checkIfPangram(String sentence) {
        int seen = 0;
        for (int i = 0; i < sentence.length(); i++) {
            seen |= (1 << (sentence.charAt(i) - 'a'));
            if (seen == (1 << 26) - 1) { // 26 set bits = 67,108,863
                return true;
            }
        }
        return seen == (1 << 26) - 1;
    }
}
