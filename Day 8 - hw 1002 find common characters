import java.util.ArrayList;
import java.util.List;

class Solution {
    public List<String> commonChars(String[] words) {
        List<String> result = new ArrayList<>();

        // Loop through each character 'a' through 'z'
        for (char c = 'a'; c <= 'z'; c++) {
            int minCount = Integer.MAX_VALUE;

            // Find how many times 'c' appears in each word
            for (String word : words) {
                int count = 0;
                for (char ch : word.toCharArray()) {
                    if (ch == c) {
                        count++;
                    }
                }
                // Keep track of the minimum count across all words
                minCount = Math.min(minCount, count);
            }

            // Add the character to our result list as many times as it appears in all words
            for (int i = 0; i < minCount; i++) {
                result.add(String.valueOf(c));
            }
        }

        return result;
    }
}
